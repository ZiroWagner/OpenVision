# OpenVision Configuration
# Copy this file to .env and adjust values

# Database
DATABASE_URL=postgresql+asyncpg://openvision:openvision@postgres:5432/openvision
POSTGRES_USER=openvision
POSTGRES_PASSWORD=openvision
POSTGRES_DB=openvision

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Storage
STORAGE_PATH=/app/storage

# App
APP_NAME=OpenVision
APP_VERSION=0.1.0
DEBUG=false

# Alert channels (configure in Fase 6)
TELEGRAM_BOT_TOKEN=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
